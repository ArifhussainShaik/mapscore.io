# =============================================================================
# Copy this file to .env.local and fill in values:  cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Auth (login will NOT work without these)
# -----------------------------------------------------------------------------
# Your site URL. Local dev = http://localhost:3000. On Vercel set to your domain
# e.g. https://mapscore-jade.vercel.app
NEXTAUTH_URL=http://localhost:3000
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# Google OAuth credentials (Google Cloud Console > Credentials > OAuth client ID).
# Authorized redirect URI must be:  <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_ID=
GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# REQUIRED — Database (login + audits store users/sessions/audits here)
# -----------------------------------------------------------------------------
MONGODB_URI=

# -----------------------------------------------------------------------------
# TESTING — set true to bypass the paywall/credits so you can run audits
# without buying. Leave unset/false in production.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TESTING_MODE=false

# -----------------------------------------------------------------------------
# Audit data providers (needed for real audit results)
# -----------------------------------------------------------------------------
SERPER_API_KEY=               # business search
GOOGLE_PLACES_API_KEY=        # place details
GOOGLE_PAGESPEED_API_KEY=     # website speed signal
OUTSCRAPER_API_KEY=           # reviews/photos scraping
DATAFORSEO_LOGIN=             # rankings (optional)
DATAFORSEO_PASSWORD=
OPENAI_API_KEY=               # action-plan generation

# -----------------------------------------------------------------------------
# Queue / cache (optional — without it audits run synchronously inline)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# -----------------------------------------------------------------------------
# Payments — Dodo (https://dodopayments.com)
# -----------------------------------------------------------------------------
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode      # test_mode | live_mode
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/dashboard
DODO_WEBHOOK_SECRET=
# Product IDs from the Dodo dashboard (map to credit packages)
DODO_PRODUCT_STARTER=
DODO_PRODUCT_BASIC=
DODO_PRODUCT_PRO=
DODO_PRODUCT_LIFETIME=
# Optional direct checkout links
DODO_STARTER_CHECKOUT_URL=
DODO_GROWTH_CHECKOUT_URL=
DODO_AGENCY_CHECKOUT_URL=

# -----------------------------------------------------------------------------
# Email — Resend (optional)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
